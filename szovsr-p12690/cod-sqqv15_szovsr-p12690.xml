      <div xml:id="szovsr-p12690"><!-- t7l7prae -->
        <head xml:id="szovsr-p12690-Hd1e101">Praeambulum</head>
        <p xml:id="szovsr-p12690-d1e103">
          <cb ed="#P" n="b"/>
          <lb ed="#P" n="13"/>LIBER SEPTIMUS
          <lb ed="#P" n="14"/>DE PROFESSIONE INVALIDA.
        </p>
        <p xml:id="szovsr-p12690-d1e112">
          <cb ed="#P" n="c"/>
          <lb ed="#P" n="15"/>Quamvis professio invalida revera 
          profes<lb break="no" ed="#P" n="16"/>sio non sit, nec religiosum faciat, nihilominus
          <lb ed="#P" n="17"/>necesse est de illa in particulari dicere, tum
          <lb ed="#P" n="18"/>ut sciamus quid remedii illi possit et debeat
          <lb ed="#P" n="19"/>adhiberi, tum etiam ut videamus an aliquos
          <lb ed="#P" n="20"/>effectus inducat, aliquamve obligationem 
          re<lb break="no" ed="#P" n="21"/>linquat.
        </p>
      </div>
