      <div xml:id="szovsr-p94764"><!-- t7l6prae -->
        <head xml:id="szovsr-p94764-Hd1e101">Praeambulum</head>
        <p xml:id="szovsr-p94764-d1e103">
          <pb ed="#P" n="381"/>
          <cb ed="#P" n="a"/>
          <lb ed="#P" n="1"/>LIBER SEXTUS
          <lb ed="#P" n="2"/>DE PROFISSIONE RELIGIOSA.
        </p>
        <p xml:id="szovsr-p94764-d1e114">
          <lb ed="#P" n="3"/>Post novitiatum completum, sequitur 
          reli<lb break="no" ed="#P" n="4"/>giosa professio, per quam religiosus status 
          sub<lb break="no" ed="#P" n="5"/>stantialiter consummatur, et ideo de illa 
          con<lb break="no" ed="#P" n="6"/>sequenter dicendum est. Primo, quam sit 
          ne<lb break="no" ed="#P" n="7"/>cessaria ad religiosum statum. Deinde, in quo
          <lb ed="#P" n="8"/>substantialiter consistat, et quas causas vel
          <lb ed="#P" n="9"/>conditiones requirat ut valida sit, et quot 
          mo<lb break="no" ed="#P" n="10"/>dis fieri possit, seu quotuplex sit. Ac deinde
          <lb ed="#P" n="11"/>quas proprietates et effectus habeat. Quia vero
          <lb ed="#P" n="12"/>professio et expresse et tacite fieri potest, et
          <lb ed="#P" n="13"/>illa, quae est expressa, et quasi exemplar 
          alte<lb break="no" ed="#P" n="14"/>rius, et professio simpliciter, ideo de illa prius
          <lb ed="#P" n="15"/>et praecipue hic disputamus ; postea vcro quae
          <lb ed="#P" n="16"/>ad aliam pertinent, addemus.
        </p>
      </div>
    </body>
