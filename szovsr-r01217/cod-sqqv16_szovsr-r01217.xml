    <body>
      <div xml:id="szovsr-r01217"><!-- t10l4prae -->
        <head xml:id="szovsr-r01217-Hd1e101">Praeambulum</head>
        <p xml:id="szovsr-r01217-d1e103">
          <pb ed="#P" n="699"/>
          <cb ed="#V" n="a"/>
          <lb ed="#C" n="1"/>LIBER QUARTUS
          <lb ed="#C" n="2"/>DE
          <lb ed="#C" n="3"/>VOTIS SIMPLICIBUS CASTITATIS
          <lb ed="#C" n="4"/>PAUPERTATIS, ETC., QUE IN SOCIETATE JESU EMITTUNTUR.
        </p>
        <p xml:id="szovsr-r01217-d1e119">
          <cb ed="#V" n="b"/>
          <lb ed="#C" n="5"/>Explicata qualitate vinculi scholarium in
          <lb ed="#C" n="6"/>Societate approbatorum , ad exactam hujus
          <lb ed="#C" n="7"/>status declarationem, necesse est de singulis
          <lb ed="#C" n="8"/>votis, prout in eadem Societate nuncupantur,
          <lb ed="#C" n="9"/>aliquid sigillatim dicere; postea vero in 
          se<lb break="no" ed="#C" n="10"/>quentibus libris de studiis aliisque actionibus
          <lb ed="#C" n="11"/>tractabimus.
        </p>
      </div>
    </body>
