      <div xml:id="szovsr-k00843"><!-- t1-l3prae -->
        <head>Praeambulum</head>
        <p>
          <cb ed="#P" n="f"/>
          <lb ed="#P" n="46"/>LIBER TERTIUS.
          <lb ed="#P" n="47"/>DE HABITU VIRTUTIS RELIGIONIS.
        </p>
        <p>
          <cb ed="#P" n="g"/>
          <lb ed="#P" n="48"/>Explicatis objecto et actibus religionis, 
          su<lb break="no" ed="#P" n="49"/>perest ut de ipso habitu, seu, quod idem est,
          <lb ed="#P" n="50"/>de propria virtute tractemus, de qua prius
          <lb ed="#P" n="51"/>quaedam generalia expediemus, quia ex 
          dic<lb break="no" ed="#P" n="52"/>tis faciliora sunt; deinde distinctionem illius
          <lb ed="#P" n="53"/>a caeteris virtutibus investigabimus, ut 
          tan<lb break="no" ed="#P" n="54"/>dem, quod difficilius est, unitatem ejus, ac
          <lb ed="#P" n="55"/>specificam rationem investigare possimus.
        </p>
      </div>
