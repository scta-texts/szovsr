      <div xml:id="szovsr-m18470"><!-- t5l4prae -->
        <head xml:id="szovsr-m18470-Hd1e101">Praeambulum</head>
        <p xml:id="szovsr-m18470-d1e103">
          <cb ed="#P" n="c"/>
          <lb ed="#P" n="11"/>LIBER QUARTUS
          <lb ed="#P" n="12"/>DE ADIURATIONE.
        </p>
        <p xml:id="szovsr-m18470-d1e112">
          <cb ed="#P" n="d"/>
          <lb ed="#P" n="13"/>Hunc actum posuit D. Thomas inter 
          exter<lb break="no" ed="#P" n="14"/>nos actus religionis 2. 2, q. 90, et habere 
          po<lb break="no" ed="#P" n="15"/>test rationem formalem distinctam a reliquis;
          <lb ed="#P" n="16"/>habetque quamdam afhinitatem cum 
          jura<lb break="no" ed="#P" n="17"/>mento, sicut in voce, ita etiam in 
          invocatio<lb break="no" ed="#P" n="18"/>ne nominis Dei, ideoque convenienter in
          <lb ed="#P" n="19"/>hunc locum cadit de illo disputatio. Quae licet
          <lb ed="#P" n="20"/>brevis et facilis sit, praetermitti omnino non
          <lb ed="#P" n="21"/>debuit, tum propter materiae complcmentum,
          <lb ed="#P" n="22"/>tum quia et ad nonnullos casus morales, et
          <lb ed="#P" n="23"/>ad occurrendum aliquibus haereticis utilis 
          es<lb break="no" ed="#P" n="24"/>se potest. Primo ergo explicabimus quid sit
          <lb ed="#P" n="25"/>haec adjuratio, et cur inter actus religionis
          <lb ed="#P" n="26"/>ponatur. Deinde videbimus quae res et 
          quo<lb break="no" ed="#P" n="27"/>modo adjurari possint; ac demum constabit
          <lb ed="#P" n="28"/>quid vitii vel superstitionis in hoc genere 
          ac<lb break="no" ed="#P" n="29"/>tionis misceri possit.
        </p>
      </div>
    </body>
