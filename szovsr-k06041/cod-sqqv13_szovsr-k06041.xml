    <body>
      <div xml:id="szovsr-k06041"><!-- t2-l2prae -->
        <head xml:id="szovsr-k06041-Hd1e101">Praeambulum</head>
        <p xml:id="szovsr-k06041-d1e103">
          <pb ed="#P" n="243"/>
          <cb ed="#P" n="a"/>
          <lb ed="#P" n="1"/>LIBER SECUNDUS.
          <lb ed="#P" n="2"/>DE SACRORUM
          <lb ed="#P" n="3"/>SEU FESTORUM DIBRUM
          <lb ed="#P" n="4"/>OBSERVATIONE ET PRJECEPTO.
        </p>
        <p xml:id="szovsr-k06041-d1e119">
          <lb ed="#P" n="5"/>Hactenus explicuimus actiones in quibus 
          ex<lb break="no" ed="#P" n="6"/>ternus Dei cultus continetur, vel ad illum
          <lb ed="#P" n="7"/>proxime ordinantur; nunc duae circumstantiae
          <lb ed="#P" n="8"/>ad hujusmodi actiones necessariae explicandae
          <lb ed="#P" n="9"/>supersunt, qua sunt tempus et locus: nam
          <lb ed="#P" n="10"/>de his etiam circumstantiis praecepta sunt 
          da<lb break="no" ed="#P" n="11"/>ta, ad virtutem religionis pertinentia, quorum
          <lb ed="#P" n="12"/>declaratio ad hunc locum maxime pertinet.
          <lb ed="#P" n="13"/>Dicemus ergo prius de tempore, postea de loco.
          <lb ed="#P" n="14"/>De tempore autem duo praecepta data nobis
          <lb ed="#P" n="15"/>sunt: unum divinum, quod est tertium 
          Deca<lb break="no" ed="#P" n="16"/>logi, de sanctificatione sabbathi; aliud 
          huma<lb break="no" ed="#P" n="17"/>num, quod est primum inter generalia 
          Eccle<lb break="no" ed="#P" n="18"/>siae praecepta, quod est de festorum 
          observa<lb break="no" ed="#P" n="19"/>tione : qua duo praecepta in hujus libri 
          dis<lb break="no" ed="#P" n="20"/>cursu a nobis explicanda sunt.
        </p>
      </div>
    </body>
