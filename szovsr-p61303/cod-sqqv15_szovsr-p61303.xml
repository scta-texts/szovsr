      <div xml:id="szovsr-p61303"><!-- t7l4prae -->
        <head xml:id="szovsr-p61303-Hd1e101">Praeambulum</head>
        <p xml:id="szovsr-p61303-d1e103">
          <cb ed="#P" n="b"/>
          <lb ed="#P" n="29"/>LIBER QUARTUS
          <lb ed="#P" n="30"/>ASSUMENDI STATUM RELIGIONIS.
        </p>
        <p xml:id="szovsr-p61303-d1e112">
          <lb ed="#P" n="31"/>Quamvis hoc votum simplex sit, est enim
          <lb ed="#P" n="32"/>mera promissio de futuro, qua» statum 
          religio<lb break="no" ed="#P" n="33"/>sum non constituit, sed ad illum ordinatur,
          <lb ed="#P" n="34"/>nihilominus illius tractationem in hunc locum
          <lb ed="#P" n="35"/>reservavimus, quia cum tale votum pro 
          objec<lb break="no" ed="#P" n="36"/>to habeat ipsum religiosum statum, oportuit
          <lb ed="#P" n="37"/>prius de ipso statu notitiam aliquam 
          pramit<lb break="no" ed="#P" n="38"/>tere, ac deinceps de illius promissione 
          sermo<lb break="no" ed="#P" n="39"/>nem facere. Dicemus ergo prius deobligatione
          <lb ed="#P" n="40"/>hujus voti, quatenus ex tali materia specialem
          <lb ed="#P" n="41"/>aliquam proprietatem vel conditionem habet;
          <cb ed="#P" n="c"/>
          <lb ed="#P" n="42"/>postea de modis quibus cessare possit haec 
          obli<lb break="no" ed="#P" n="43"/>gatio; nam caetera, quae communia sunt, ex
          <lb ed="#P" n="44"/>generali doctrina de voto sunt potius 
          suppo<lb break="no" ed="#P" n="45"/>nenda.
        </p>
      </div>
    </body>
