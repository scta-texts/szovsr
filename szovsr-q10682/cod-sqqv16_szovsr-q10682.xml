      <div xml:id="szovsr-q10682"><!-- t9l1prae -->
        <head xml:id="szovsr-q10682-Hd1e101">Praeambulum</head>
        <p xml:id="szovsr-q10682-d1e103">
          <pb ed="#P" n="427"/>
          <cb ed="#P" n="a"/>
          <lb ed="#P" n="1"/>LIBER PRIMUS
          <lb ed="#P" n="2"/>DE
          <lb ed="#P" n="3"/>VARIETATE RELIGIONUM IN GENERE.
        </p>
        <p xml:id="szovsr-q10682-d1e116">
          <lb ed="#P" n="4"/>Ordo et partitio hujus tractatus. — 
          Post<lb break="no" ed="#P" n="5"/>quam ea omnia explicuimus, quae de statu 
          re<lb break="no" ed="#P" n="6"/>ligioso absolute spectato consideranda 
          occur<lb break="no" ed="#P" n="7"/>runt, quoniam propositum nostrum est, ea
          <lb ed="#P" n="8"/>omnia in religione Societatis specialiter 
          con<lb break="no" ed="#P" n="9"/>templari, et pro viribus explicare, ut 
          comple<lb break="no" ed="#P" n="10"/>ia doctrina sit, necesse est de distinctione et
          <lb ed="#P" n="11"/>varietate religionum aliqua praemittere. 
          Pos<lb break="no" ed="#P" n="12"/>sunt autem religiones distingui vel per 
          quae<lb break="no" ed="#P" n="13"/>dam generalia capita, seu conditiones et fines
          <lb ed="#P" n="14"/>earum, ut religio contemplativa, vel activa,
          <lb ed="#P" n="15"/>etc., vel per species proprias earum, ut 
          Prae<lb break="no" ed="#P" n="16"/>dicatorum, Minorum, etc.; hoc ergo libro 
          pri<lb break="no" ed="#P" n="17"/>orem divisionem, in sequenti vero posteriorem
          <lb ed="#P" n="18"/>explicabimus.
        </p>
      </div>
    </body>
