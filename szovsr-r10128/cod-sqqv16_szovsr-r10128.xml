      <div xml:id="szovsr-r10128"><!-- t10l10prae -->
        <head xml:id="szovsr-r10128-Hd1e101">Praeambulum</head>
        <p xml:id="szovsr-r10128-d1e103">
          <cb ed="#V" n="c"/>
          <lb ed="#C" n="44"/>LIBER DECIMUS
          <lb ed="#C" n="45"/>DE REGIMINE SOCIETATTS
          <lb ed="#C" n="46"/>ET CONSEQUENTER DE PRJELATIS EJUS.
        </p>
        <p xml:id="szovsr-r10128-d1e114">
          <cb ed="#V" n="d"/>
          <lb ed="#C" n="47"/>Explicuimus omnia, quae ad statum, 
          per<lb break="no" ed="#C" n="48"/>fectionem et ministeria hujus religionis 
          spec<lb break="no" ed="#C" n="49"/>tant ; solum superest ut dicamus de modo 
          gu<lb break="no" ed="#C" n="50"/>bernationis ejus; nam ex illa maxime pendet,
          <lb ed="#C" n="51"/>et conservatio religionis, et executio omnium
          <cb ed="#V" n="e"/>
          <lb ed="#C" n="52"/>mediorum quibus ad suam et aliorum 
          perfec<lb break="no" ed="#C" n="53"/>tionem uti debet. Quoniam autem 
          guberna<lb break="no" ed="#C" n="54"/>tio per Praelatos, et secundum regulam fit;
          <lb ed="#C" n="55"/>simul de utrisque hoc in libro dicemus , 
          pri<lb break="no" ed="#C" n="56"/>mo quidem generatim, scu in communi; de-
          <pb ed="#P" n="1058"/>
          <cb ed="#V" n="a"/>
          <lb ed="#C" n="1"/>inde vero ad illa particularia descendendo,
          <lb ed="#C" n="2"/>quae ad hujus tractatus complementum 
          neces<lb break="no" ed="#C" n="3"/>saria videbuntur.
        </p>
      </div>
    </body>
