      <div xml:id="szovsr-k11635"><!-- t3-l2prae -->
        <head xml:id="szovsr-k11635-Hd1e101">Praeambulum</head>
        <p xml:id="szovsr-k11635-d1e103">
          <cb ed="#P" n="d"/>
          <lb ed="#P" n="39"/>LIBER SECUNDUS
          <lb ed="#P" n="40"/>DE SUPERSTITIONE.
        </p>
        <p xml:id="szovsr-k11635-d1e112">
          <cb ed="#P" n="e"/>
          <lb ed="#P" n="41"/>Superstitio, ex communi sententia, vitium
          <lb ed="#P" n="42"/>est religioni Dei contrarium, ut in superioribus
          <lb ed="#P" n="43"/>tactum est, et mox latius videbimus. Non est
          <lb ed="#P" n="44"/>autem una tantum species vitii, sed quasi 
          ge<lb break="no" ed="#P" n="45"/>nus quoddam proximum multas sub se 
          conti<lb break="no" ed="#P" n="46"/>nens species; nam quaedam superstitio est
          <lb ed="#P" n="47"/>circa Deum verum, alia circa Deos falsos, vel
          <lb ed="#P" n="48"/>expresse, vel tacite, de quibus omnibus in 
          dis<lb break="no" ed="#P" n="49"/>cursu hujus lib:i dicendum est.
        </p>
      </div>
